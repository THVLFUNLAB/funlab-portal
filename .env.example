# ============================================================
# FUNLAB PORTAL - Biến Môi Trường (Environment Variables)
# Sao chép file này thành .env.local và điền giá trị thật
# Trên Vercel: cấu hình tại Settings > Environment Variables
# ============================================================

# --- Supabase (BẮT BUỘC) ---
# Lấy tại: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# --- Supabase Service Role (SECRET - CHỈ DÙNG PHÍA SERVER) ---
# CẢNH BÁO: Không bao giờ expose key này ở client-side!
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- Google Generative AI / Gemini (BẮT BUỘC cho Chatbox) ---
# Lấy tại: https://aistudio.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your_google_ai_api_key_here

# --- Admin Dashboard (TÙY CHỌN) ---
# Mã code để đăng nhập vào trang Admin. Mặc định: "funlab2024"
NEXT_PUBLIC_ADMIN_CODE=your_admin_code_here

# --- Backend API (Render) ---
# Điền URL Backend sau khi deploy lên Render
NEXT_PUBLIC_API_URL=https://your-backend-url.onrender.com
